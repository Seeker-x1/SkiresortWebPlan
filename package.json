  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview:site": "node scripts/build-static-preview.mjs && node scripts/build-evaluation-html.mjs",
    "preview:evaluation": "node scripts/build-evaluation-html.mjs",
    "preview:static": "node scripts/build-static-preview.mjs && node scripts/build-evaluation-html.mjs && npx --yes serve public -p 5500",
