    "lp:batch-status": "node scripts/lp-factory/batch-status.mjs",
    "lp:research-prompt": "node scripts/lp-factory/build-deep-research-prompt.mjs",
    "lp:cursor-handoff": "node scripts/lp-factory/cursor-handoff.mjs",
    "lp:batch-update": "node scripts/lp-factory/batch-update.mjs",
    "lp:import-batch": "node scripts/lp-factory/import-batch-from-gemini.mjs",
    "lp:sales-proposal": "node scripts/lp-factory/build-sales-proposal.mjs",
    "lp:detect-inbox": "node scripts/lp-factory/detect-inbox-reports.mjs",
    "lp:deep-research": "node scripts/lp-factory/run-deep-research.mjs",
    "lp:import-report": "node scripts/lp-factory/import-gem-report.mjs",
    "lp:auto": "node scripts/lp-factory/run-lp-auto.mjs",
    "lp:ship": "node scripts/lp-factory/ship-lp.mjs"
